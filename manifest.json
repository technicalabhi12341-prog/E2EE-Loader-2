{
  "manifest_version": 3,

  "name": "E2EE Loader By Ravi King",

  "short_name": "RAVI KING",

  "version": "1.7",

  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "contextMenus"
  ],

  "host_permissions": [
    "https://technicalabhi12341-prog.github.io/*",
    "https://files.catbox.moe/*",
    "<all_urls>"
  ],

"background": {
  "service_worker": "background.js"
},

  "action": {
    "default_popup": "index.html",
    "default_icon": "icon128.png"
  },

  "offline_enabled": true,

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

"content_scripts": [
  {
    "matches": [
      "*://*.facebook.com/*",
      "*://*.messenger.com/*"
    ],

    "js": [
      "content_script.js"
    ],

    "run_at": "document_idle"
  }
],

  "web_accessible_resources": [
    {
      "resources": [
        "keys.json",
        "music.js",
        "music.mp3"
],

      "matches": [
        "<all_urls>"
      ]
    }
  ]
}